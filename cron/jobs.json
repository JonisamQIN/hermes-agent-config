    {
      "id": "7f1577960c5d",
      "name": "\u6bcf\u65e5\u8bad\u8bb0\u6570\u636e\u540c\u6b65\u4e0e\u590d\u76d8",
      "prompt": "## \u4efb\u52a1\uff1a\u6bcf\u65e5\u8bad\u8bb0\u6570\u636e\u540c\u6b65\u4e0e\u590d\u76d8\n\n\u6bcf\u5929\u665a\u4e0a10\u70b9\u81ea\u52a8\u6267\u884c\uff0c\u83b7\u53d6\u5f53\u65e5\u8bad\u8bb0\u8bad\u7ec3\u6570\u636e\uff0c\u5165\u5e93\u5e76\u751f\u6210\u7b80\u77ed\u590d\u76d8\u3002\n\n### \u6570\u636e\u6e90\n- \u8bad\u8bb0API: POST https://trains.xunjiapp.cn/api_trains_for_llm\n- \u8ba4\u8bc1: Bearer xjllm_c2079c8a6d0b6ec141effbf894b6ed99b143bb557729fcac\n- \u7f13\u5b58\u76ee\u5f55: ~/.hermes/train_cache/\n\n### \u6267\u884c\u6b65\u9aa4\n\n**Step 1: \u83b7\u53d6\u4eca\u65e5\u8bad\u7ec3\u6570\u636e**\n```python\nimport sys, gzip, json, os\nfrom datetime import date\n\nsys.path.insert(0, \"/root/.hermes/scripts\")\n\n# \u8bfb\u53d6API\u6a21\u5757\nBASE_URL = \"https://trains.xunjiapp.cn/api_trains_for_llm\"\nAPIKEY = \"xjllm_c2079c8a6d0b6ec141effbf894b6ed99b143bb557729fcac\"\nCACHE_DIR = os.path.expanduser(\"~/.hermes/train_cache\")\nDB_PATH = os.path.expanduser(\"~/.hermes/fitness_data/fitness_log.json\")\n\ntoday = date.today().strftime(\"%Y-%m-%d\")\n\n# \u8c03\u7528API\u83b7\u53d6\u4eca\u65e5\u6570\u636e\nimport urllib.request, urllib.error\npayload = json.dumps({\"datestr\": today}).encode('utf-8')\nreq = urllib.request.Request(BASE_URL, data=payload,\n    headers={\"Authorization\": f\"Bearer {APIKEY}\", \"Content-Type\": \"application/json\"}, method=\"POST\")\nwith urllib.request.urlopen(req, timeout=30) as resp:\n    raw = resp.read()\n    try:\n        data = json.loads(gzip.decompress(raw).decode('utf-8'))\n    except:\n        data = json.loads(raw.decode('utf-8'))\n\nres = data.get(\"res\", [])\nprint(f\"\u4eca\u65e5({today})\u8bad\u8bb0\u8bb0\u5f55: {len(res)}\u6761\")\nfor item in res:\n    print(item[:200])\n```\n\n**Step 2: \u89e3\u6790\u6bcf\u6761\u8bb0\u5f55**\n\u8bad\u8bb0\u8bb0\u5f55\u683c\u5f0f: `260508,id:xxx,\u8bad\u7ec3\u540d,train_time:xxx,calorie:N,1.\u52a8\u4f5c\u540d,1\u7ec4,\u91cd\u91cf,\u6b21\u6570,time:xs,...`\n- \u7528\u9017\u53f7\u5206\u5272\uff0c\u7b2c0\u6bb5\u662f\u65e5\u671f\u7f16\u7801(YYMMDD)\n- calorie:N \u627e\u5361\u8def\u91cc\n- N.\u52a8\u4f5c\u540d \u627e\u52a8\u4f5c\uff08\u6b63\u5219: `(\\d+)\\.([^,]+)`\uff09\n\n**Step 3: \u66f4\u65b0\u6570\u636e\u5e93**\n```python\nwith open(DB_PATH) as f:\n    db = json.load(f)\n\nexisting_dates = {t.get(\"date\") for t in db.get(\"training_sessions\", [])}\n\nfor raw in res:\n    # \u89e3\u6790\u8bad\u7ec3\u540d\u3001\u5361\u8def\u91cc\u3001\u52a8\u4f5c\n    parts = raw.split(',')\n    date_code = parts[0]  # \u5982 260508\n    datestr = f\"20{date_code[:2]}-{date_code[2:4]}-{date_code[4:6]}\"\n    \n    # \u627e\u8bad\u7ec3\u540d\uff08\u7b2c\u4e00\u4e2a\u4e2d\u6587/\u82f1\u6587\u975e\u7279\u6b8a\u5b57\u6bb5\uff09\n    train_name = \"\"\n    for p in parts[1:5]:\n        stripped = p.strip()\n        if stripped and not any(stripped.startswith(x) for x in ['id:','train_time:','calorie:']):\n            import re\n            if re.search(r'[\\u4e00-\\u9fa5A-Za-z]', stripped):\n                train_name = stripped\n                break\n    \n    # \u627ecalorie\n    calorie = 0\n    for p in parts:\n        if p.startswith('calorie:'):\n            try:\n                calorie = int(p[8:])\n            except:\n                pass\n    \n    # \u627e\u52a8\u4f5c\n    exercises = []\n    import re\n    for m in re.finditer(r'(\\d+)\\.([^,]+)', raw):\n        exercises.append({\"name\": m.group(2).strip(), \"sets\": []})\n    \n    # \u6784\u5efa\u8bb0\u5f55\n    record = {\n        \"date\": datestr,\n        \"training_name\": train_name,\n        \"calorie\": calorie,\n        \"exercises\": exercises,\n        \"notes\": \"\u6bcf\u65e5\u81ea\u52a8\u540c\u6b65\"\n    }\n    \n    if datestr not in existing_dates:\n        db.setdefault(\"training_sessions\", []).append(record)\n        print(f\"\u2705 \u65b0\u589e {datestr} {train_name} {calorie}kcal\")\n    else:\n        print(f\"\u23ed\ufe0f \u5df2\u5b58\u5728 {datestr}\uff0c\u8df3\u8fc7\")\n\nwith open(DB_PATH, 'w') as f:\n    json.dump(db, f, ensure_ascii=False, indent=2)\n```\n\n**Step 4: \u751f\u6210\u590d\u76d8**\n```python\n# \u8bfb\u53d6\u5f53\u5929\u6240\u6709\u8bad\u7ec3\ntoday_records = [t for t in db.get(\"training_sessions\", []) if t.get(\"date\") == today]\n\nif today_records:\n    total_cal = sum(t.get(\"calorie\", 0) for t in today_records)\n    names = [t.get(\"training_name\", \"?\") for t in today_records]\n    ex_counts = [len(t.get(\"exercises\", [])) for t in today_records]\n    \n    report = f\"\"\"\ud83d\udcca {today} \u8bad\u7ec3\u65e5\u62a5\n\n\u8bad\u7ec3: {', '.join(names)}\n\u52a8\u4f5c\u6570: {sum(ex_counts)}\u4e2a\n\u6d88\u8017: {total_cal}kcal\"\"\"\nelse:\n    report = f\"\ud83d\udcca {today} \u65e0\u8bad\u8bb0\u8bad\u7ec3\u8bb0\u5f55\"\n\nprint(report)\n```\n\n### \u8f93\u51fa\u8981\u6c42\n- \u6700\u7ec8\u8f93\u51fa\u4e00\u6bb5\u7b80\u6d01\u7684\u65e5\u62a5\u6587\u5b57\n- \u5305\u542b\u65e5\u671f\u3001\u8bad\u7ec3\u540d\u79f0\u3001\u603b\u6d88\u8017\u3001\u52a8\u4f5c\u6570\n- \u5982\u65e0\u8bad\u7ec3\u5219\u63d0\u793a\"\u4eca\u65e5\u65e0\u8bad\u7ec3\u8bb0\u5f55\"\n- \u4ec5\u6587\u5b57\uff0c\u4e0d\u9700\u8981\u8868\u683c\u683c\u5f0f",
